{
  "dashboard": {
    "id": null,
    "title": "Spring Boot Microservices Dashboard",
    "tags": ["spring-boot", "microservices"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "JVM Memory Used",
        "type": "graph",
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{job=~\".*\"}",
            "legendFormat": "{{job}} - {{area}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "HTTP Requests",
        "type": "graph",
        "targets": [
          {
            "expr": "http_server_requests_seconds_count{job=~\".*\"}",
            "legendFormat": "{{job}} - {{method}} {{uri}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "5s",
    "schemaVersion": 27,
    "version": 0,
    "links": []
  }
}